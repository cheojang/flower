# ───────────────────────────────────────────────
# 온실(ONSIL) 꽃집 - 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
#   cp .env.example .env
# ───────────────────────────────────────────────

# NextAuth 세션 암호화 키 (필수)
# 아무 긴 무작위 문자열. 생성: `openssl rand -base64 32`
AUTH_SECRET="여기에-무작위-문자열-넣기"
# (admin 쿠키 서명에도 사용됩니다)
NEXTAUTH_SECRET="여기에-무작위-문자열-넣기"

# 관리자 페이지 비밀번호 (/admin)
ADMIN_PASSWORD="onsil1234"

# ───────────── 카카오 로그인 (지금 사용) ─────────────
# https://developers.kakao.com 에서 앱 생성 →
#   - 카카오 로그인 활성화
#   - Redirect URI: http://localhost:3000/api/auth/callback/kakao (배포 시 도메인으로 교체)
#   - REST API 키 = KAKAO_CLIENT_ID
#   - 보안 > Client Secret 생성 = KAKAO_CLIENT_SECRET
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ───────────── 네이버 로그인 (나중에 키만 넣으면 자동 활성화) ─────────────
# https://developers.naver.com 애플리케이션 등록
#   - Callback URL: http://localhost:3000/api/auth/callback/naver
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ───────────── 구글 로그인 (나중에 키만 넣으면 자동 활성화) ─────────────
# https://console.cloud.google.com OAuth 동의화면 + 사용자 인증 정보
#   - 승인된 리디렉션 URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
